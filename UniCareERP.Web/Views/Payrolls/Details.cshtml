@model UniCareERP.Application.DTOs.HR.PayrollDto

@{
    ViewData["Title"] = "Payroll Details";
}

<h1>Payroll Details</h1>

<div>
    <h4>Payroll</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EmployeeName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EmployeeName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PayPeriodStartDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PayPeriodStartDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PayPeriodEndDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PayPeriodEndDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.GrossSalary)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.GrossSalary)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NetSalary)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NetSalary)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalDeductions)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalDeductions)
        </dd>
    </dl>
</div>

<h4>Payslips</h4>
<table class="table">
    <thead>
        <tr>
            <th>
                Description
            </th>
            <th>
                Amount
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Payslips)
        {
            <tr>
                <td>
                    @item.Description
                </td>
                <td>
                    @item.Amount
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId">Back to List</a>
</div>
