@{
    ViewData["Title"] = "Generate Payroll";
}

<h1>Generate Payroll</h1>

<form asp-action="Generate" method="post">
    <div class="form-group">
        <label for="employeeId">Employee</label>
        <select name="employeeId" class="form-control">
            @foreach (var employee in ViewBag.Employees)
            {
                <option value="@employee.Id">@employee.FullName</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label for="payPeriodStartDate">Pay Period Start Date</label>
        <input type="date" name="payPeriodStartDate" class="form-control" />
    </div>
    <div class="form-group">
        <label for="payPeriodEndDate">Pay Period End Date</label>
        <input type="date" name="payPeriodEndDate" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Generate</button>
</form>
