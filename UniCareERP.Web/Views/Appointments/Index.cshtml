@model IEnumerable<UniCareERP.Application.DTOs.Appointments.AppointmentDto>
@using UniCareERP.Domain.Enums

@{
    ViewData["Title"] = "Appointments Schedule";
    var currentSearchDate = ViewData["CurrentSearchDate"] as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var currentDoctorId = ViewData["CurrentDoctorId"] as string;
}

<h1>@ViewData["Title"]</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="row mb-3">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="row gy-2 gx-2 align-items-center">
            <div class="col-auto">
                <label for="searchDate" class="form-label">Date:</label>
                <input type="date" id="searchDate" name="searchDate" value="@currentSearchDate" class="form-control" />
            </div>
            <div class="col-auto">
                <label for="doctorId" class="form-label">Doctor:</label>
                <select name="doctorId" asp-items="ViewBag.DoctorId" class="form-select">
                    <option value="">-- All Doctors --</option>
                </select>
            </div>
            <div class="col-auto align-self-end">
                <button type="submit" class="btn btn-info">Filter</button>
                 <a asp-action="Index" class="btn btn-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
    <div class="col-md-4 text-end align-self-center">
         <a asp-action="Create" asp-route-initialDate="@currentSearchDate" class="btn btn-primary">Schedule New Appointment</a>
    </div>
</div>

@* The existing table-based list will be replaced by the calendar *@
@*
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Time</th>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Service Type</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppointmentDateTime.ToString("HH:mm") - @item.EndDateTime.ToString("HH:mm") (@item.DurationMinutes mins)</td>
                    <td>
                        <a asp-controller="Patients" asp-action="Details" asp-route-id="@item.PatientId">
                            @Html.DisplayFor(modelItem => item.PatientName)
                        </a>
                        (@Html.DisplayFor(modelItem => item.PatientCode))
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.DoctorName)</td>
                    <td>@Html.DisplayFor(modelItem => item.ServiceType)</td>
                    <td>
                        <span class="badge bg-@(GetStatusBadgeClass(item.Status))">
                            @Html.DisplayFor(modelItem => item.StatusText)
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info ms-1">Details</a>
                        @if (item.Status == AppointmentStatus.Scheduled || item.Status == AppointmentStatus.Confirmed)
                        {
                            <form asp-action="Cancel" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                <input type="hidden" name="cancellationReason" value="Cancelled by staff via UI" />
                                <button type="submit" class="btn btn-sm btn-outline-warning ms-1">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">No appointments found for the selected criteria.</td>
            </tr>
        }
    </tbody>
</table>
*@

<div id="calendar"></div>

@functions {
    string GetStatusBadgeClass(AppointmentStatus status)
    {
        return status switch
        {
            AppointmentStatus.Scheduled => "secondary",
            AppointmentStatus.Confirmed => "primary",
            AppointmentStatus.Completed => "success",
            AppointmentStatus.CancelledByPatient => "warning",
            AppointmentStatus.CancelledByClinic => "warning",
            AppointmentStatus.NoShow => "danger",
            AppointmentStatus.Rescheduled => "info",
            _ => "light",
        };
    }
}

@section Styles {
    <link href="~/lib/fullcalendar/fullcalendar.min.css" rel="stylesheet" />
    <style>
        /* Custom styles for the calendar page if needed */
        #calendar {
            max-width: 1100px;
            margin: 20px auto;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/fullcalendar/fullcalendar.min.js"></script>
    <script>
        // JavaScript for FullCalendar initialization will go here in a later step
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth', // Default view
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek' // View options
                },
                events: {
                    url: '@Url.Action("GetCalendarEvents")', // API endpoint
                    failure: function() {
                        alert('There was an error while fetching events!');
                    }
                    // FullCalendar will automatically append 'start' and 'end' parameters
                },
                editable: false, // For now, not supporting drag-and-drop editing
                selectable: true, // Allow date clicking
                select: function(info) {
                    // When a date/time is selected (clicked)
                    var createUrl = '@Url.Action("Create")' + '?initialDate=' + info.startStr.substring(0,10); // Pass date part
                    if (info.allDay) {
                         // If an all-day slot in month view is clicked, default to a specific time e.g. 9 AM
                        createUrl = '@Url.Action("Create")' + '?initialDate=' + info.startStr.substring(0,10) + "T09:00:00";
                    } else {
                        // For timeGrid views, startStr includes time
                         createUrl = '@Url.Action("Create")' + '?initialDate=' + info.startStr;
                    }

                    var currentDoctorId = "@currentDoctorId"; // Get doctor from server-side filter if set
                    if(currentDoctorId){
                        createUrl += '&doctorId=' + encodeURIComponent(currentDoctorId);
                    }
                    window.location.href = createUrl;
                },
                eventClick: function(info) {
                    // When an event is clicked
                    info.jsEvent.preventDefault(); // Prevent browser from following the A tag's href if event has a URL
                    if (info.event.url) {
                        window.location.href = info.event.url; // Go to the event's details page
                    }
                },
                loading: function(isLoading) {
                    // Optionally add a loading indicator
                    // console.log(isLoading ? 'Loading events...' : 'Events loaded.');
                },
                // Set initialDate based on server-side filter if available, otherwise FullCalendar defaults to current date
                initialDate: '@currentSearchDate',

                // Optionally, you could try to re-apply doctor filter here if you modify GetCalendarEvents
                // to accept a doctorId. For now, the API fetches all doctors.
                // eventSources: [ { url: '@Url.Action("GetCalendarEvents")', extraParams: { doctorId: currentDoctorId } } ]
            });
            calendar.render();

            // If server-side doctor filter changes, you might need to refetch events.
            // This is a basic setup. A more robust solution might use JS to handle filter changes and call calendar.refetchEvents().
            var doctorDropdown = document.querySelector('select[name="doctorId"]');
            var dateInput = document.querySelector('input[name="searchDate"]');

            if(doctorDropdown) {
                doctorDropdown.addEventListener('change', function() {
                    // This form submission will reload the page and calendar will use new initialDate/doctor for initial display
                    // but GetCalendarEvents is not yet using doctorId from client-side for dynamic refetch.
                    // this.form.submit(); // Or handle with JS refetch
                });
            }
             if(dateInput) {
                dateInput.addEventListener('change', function() {
                    // this.form.submit(); // Or handle with JS refetch
                });
            }

        });
    </script>
}
