@model IEnumerable<UniCareERP.Application.DTOs.Finance.InvoiceDto>

@{
    ViewData["Title"] = "Invoices";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Invoice</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Invoice #</th>
            <th>Patient</th>
            <th>Invoice Date</th>
            <th>Due Date</th>
            <th>Total Amount</th>
            <th>Amount Due</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">@Html.DisplayFor(modelItem => item.InvoiceNumber)</a>
                </td>
                <td>
                    <a asp-controller="Patients" asp-action="Details" asp-route-id="@item.PatientId">
                        @Html.DisplayFor(modelItem => item.PatientName)
                    </a>
                </td>
                <td>@item.InvoiceDate.ToString("yyyy-MM-dd")</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@item.TotalAmount.ToString("C")</td>
                <td>@item.AmountDue.ToString("C")</td>
                <td>
                     <span class="badge bg-@(GetStatusBadgeClass(item.Status))">
                        @Html.DisplayFor(modelItem => item.StatusText)
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>


@functions {
    string GetStatusBadgeClass(UniCareERP.Domain.Enums.InvoiceStatus status)
    {
        return status switch
        {
            UniCareERP.Domain.Enums.InvoiceStatus.Draft => "secondary",
            UniCareERP.Domain.Enums.InvoiceStatus.Sent => "info",
            UniCareERP.Domain.Enums.InvoiceStatus.Paid => "success",
            UniCareERP.Domain.Enums.InvoiceStatus.PartiallyPaid => "primary",
            UniCareERP.Domain.Enums.InvoiceStatus.Overdue => "warning",
            UniCareERP.Domain.Enums.InvoiceStatus.Void => "danger",
            _ => "light",
        };
    }
}
