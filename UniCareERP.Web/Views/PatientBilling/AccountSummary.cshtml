@model UniCareERP.Application.DTOs.Finance.PatientAccountSummaryDto

@{
    ViewData["Title"] = "Patient Account Summary";
    Layout = "_PatientBillingLayout";
}

<h2>@ViewData["Title"]</h2>

<div>
    <h4>Patient: @Model.PatientName</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Total Charges
        </dt>
        <dd class = "col-sm-10">
            @Model.TotalCharges.ToString("C")
        </dd>
        <dt class = "col-sm-2">
            Total Payments
        </dt>
        <dd class = "col-sm-10">
            @Model.TotalPayments.ToString("C")
        </dd>
        <dt class = "col-sm-2">
            Current Balance
        </dt>
        <dd class = "col-sm-10">
            @Model.CurrentBalance.ToString("C")
        </dd>
    </dl>
</div>
