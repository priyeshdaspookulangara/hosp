@model UniCareERP.Application.DTOs.Finance.PatientStatementDto

@{
    ViewData["Title"] = "Patient Statement";
    Layout = "_PatientBillingLayout";
}

<h2>@ViewData["Title"]</h2>

<div>
    <h4>Statement Date: @Model.StatementDate.ToShortDateString()</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Patient ID</dt>
        <dd class="col-sm-10">@Model.PatientId</dd>
        <dt class="col-sm-2">Statement Period</dt>
        <dd class="col-sm-10">@Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</dd>
    </dl>
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Charge</th>
                <th>Credit</th>
                <th>Balance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>@item.Description</td>
                    <td>@item.Charge.ToString("C")</td>
                    <td>@item.Credit.ToString("C")</td>
                    <td>@item.Balance.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
