@model UniCareERP.Domain.Entities.Radiology.RadiologyReport

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>RadiologyReport</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="ImagingTestId" class="control-label"></label>
                <select asp-for="ImagingTestId" class="form-control" asp-items="ViewBag.ImagingTestId"></select>
                <span asp-validation-for="ImagingTestId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RadiologistId" class="control-label"></label>
                <select asp-for="RadiologistId" class="form-control" asp-items="ViewBag.RadiologistId"></select>
                <span asp-validation-for="RadiologistId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReportText" class="control-label"></label>
                <textarea asp-for="ReportText" class="form-control"></textarea>
                <span asp-validation-for="ReportText" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReportDate" class="control-label"></label>
                <input asp-for="ReportDate" class="form-control" />
                <span asp-validation-for="ReportDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
