@model UniCareERP.Application.DTOs.OperationTheatre.UpdateSurgicalTeamDto

@{
    ViewData["Title"] = "Edit Surgical Team";
}

<h1>Edit Surgical Team</h1>

<h4>SurgicalTeam</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="EditSurgicalTeam">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MemberIds" class="control-label"></label>
                <select asp-for="MemberIds" class="form-control" asp-items="ViewBag.Users"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="SurgicalTeams">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
