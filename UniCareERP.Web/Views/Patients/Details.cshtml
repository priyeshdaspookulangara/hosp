@model UniCareERP.Application.DTOs.Patients.PatientDto

@{
    ViewData["Title"] = "Patient Details";
}

<h1>@ViewData["Title"]</h1>

<div>
    <h4>@Model.FullName (@Model.PatientCode)</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Patient Code</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PatientCode)</dd>

        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.FullName)</dd>

        <dt class="col-sm-3">Date of Birth</dt>
        <dd class="col-sm-9">@Model.DateOfBirth.ToString("yyyy-MM-dd") (@Model.Age years old)</dd>

        <dt class="col-sm-3">Gender</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Gender)</dd>

        <dt class="col-sm-3">Marital Status</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.MaritalStatus)</dd>

        <dt class="col-sm-3">Phone Number</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PhoneNumber)</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Address)</dd>

        <dt class="col-sm-3">Nationality</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Nationality)</dd>

        <dt class="col-sm-3">Preferred Language</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PreferredLanguage)</dd>

        <dt class="col-sm-3 text-danger">Emergency Contact</dt>
        <dd class="col-sm-9 text-danger">
            @Model.EmergencyContactName (@Model.EmergencyContactRelationship) - @Model.EmergencyContactPhone
        </dd>

        <dt class="col-sm-3">Blood Group</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.BloodGroup)</dd>

        <dt class="col-sm-3">Allergies</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Allergies)</dd>

        <dt class="col-sm-3">Insurance Provider</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.InsuranceProvider)</dd>

        <dt class="col-sm-3">Insurance Policy #</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.InsurancePolicyNumber)</dd>

        <dt class="col-sm-3">General Notes</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.GeneralNotes)</dd>

        <dt class="col-sm-3">Registration Date</dt>
        <dd class="col-sm-9">@Model.RegistrationDate.ToString("yyyy-MM-dd HH:mm")</dd>

        <dt class="col-sm-3">Last Modified</dt>
        <dd class="col-sm-9">@Model.LastModifiedDate.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>
</div>
<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Patient</a>
    <a asp-controller="Appointments" asp-action="Create" asp-route-patientId="@Model.Id" class="btn btn-success ms-2">Schedule New Appointment</a>
    <a asp-controller="Invoices" asp-action="Create" asp-route-patientId="@Model.Id" class="btn btn-warning ms-2">Create New Invoice</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
</div>

<hr class="mt-4 mb-3"/>
<h3>Patient Appointments</h3>

@{
    var appointments = ViewBag.PatientAppointments as IEnumerable<UniCareERP.Application.DTOs.Appointments.AppointmentDto>;
}

@if (appointments != null && appointments.Any())
{
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Date & Time</th>
                <th>Doctor</th>
                <th>Service</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appt in appointments.OrderByDescending(a => a.AppointmentDateTime))
            {
                <tr>
                    <td>@appt.AppointmentDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@appt.DoctorName</td>
                    <td>@appt.ServiceType</td>
                    <td>
                        <span class="badge bg-@(GetStatusBadgeClass(appt.Status))">
                           @appt.Status.ToString()
                        </span>
                    </td>
                    <td>
                        <a asp-controller="Appointments" asp-action="Details" asp-route-id="@appt.Id" class="btn btn-xs btn-outline-info">View</a>
                        <a asp-controller="Appointments" asp-action="Edit" asp-route-id="@appt.Id" class="btn btn-xs btn-outline-primary ms-1">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No appointments found for this patient.</p>
}


@functions {
    string GetStatusBadgeClass(UniCareERP.Domain.Enums.AppointmentStatus status)
    {
        return status switch
        {
            UniCareERP.Domain.Enums.AppointmentStatus.Scheduled => "secondary",
            UniCareERP.Domain.Enums.AppointmentStatus.Confirmed => "primary",
            UniCareERP.Domain.Enums.AppointmentStatus.Completed => "success",
            UniCareERP.Domain.Enums.AppointmentStatus.CancelledByPatient => "warning",
            UniCareERP.Domain.Enums.AppointmentStatus.CancelledByClinic => "warning",
            UniCareERP.Domain.Enums.AppointmentStatus.NoShow => "danger",
            UniCareERP.Domain.Enums.AppointmentStatus.Rescheduled => "info",
            _ => "light",
        };
    }
}

<hr class="mt-4 mb-3"/>
<h3>Patient Invoices</h3>

@{
    var invoices = ViewBag.PatientInvoices as IEnumerable<UniCareERP.Application.DTOs.Finance.InvoiceDto>;
}

@if (invoices != null && invoices.Any())
{
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Invoice #</th>
                <th>Invoice Date</th>
                <th>Total</th>
                <th>Amount Due</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in invoices.OrderByDescending(i => i.InvoiceDate))
            {
                <tr>
                    <td>@inv.InvoiceNumber</td>
                    <td>@inv.InvoiceDate.ToString("yyyy-MM-dd")</td>
                    <td>@inv.TotalAmount.ToString("C")</td>
                    <td>@inv.AmountDue.ToString("C")</td>
                    <td>
                        <span class="badge bg-@(GetInvoiceStatusBadgeClass(inv.Status))">
                           @inv.Status.ToString()
                        </span>
                    </td>
                    <td>
                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.Id" class="btn btn-xs btn-outline-info">View Invoice</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No invoices found for this patient.</p>
}

@functions {
    string GetInvoiceStatusBadgeClass(UniCareERP.Domain.Enums.InvoiceStatus status)
    {
        return status switch
        {
            UniCareERP.Domain.Enums.InvoiceStatus.Draft => "secondary",
            UniCareERP.Domain.Enums.InvoiceStatus.Sent => "info",
            UniCareERP.Domain.Enums.InvoiceStatus.Paid => "success",
            UniCareERP.Domain.Enums.InvoiceStatus.PartiallyPaid => "primary",
            UniCareERP.Domain.Enums.InvoiceStatus.Overdue => "warning",
            UniCareERP.Domain.Enums.InvoiceStatus.Void => "danger",
            _ => "light",
        };
    }
}
