@{
    ViewData["Title"] = "Patients";
}

<h1>@ViewData["Title"]</h1>

<p>@ViewBag.Message</p>

<div class="alert alert-info" role="alert">
    This is a placeholder page for Patient Management. Full functionality will be implemented later.
    <br />
    Planned features: Patient Registration, Appointments, EHR/EMR, Lab, Pharmacy (dispensing).
</div>

