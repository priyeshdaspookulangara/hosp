@model IEnumerable<UniCareERP.Application.DTOs.Inventory.SaleDto>

@{
    ViewData["Title"] = "Sales History";
}

<h1>@ViewData["Title"]</h1>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Sale Number</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Payment Method</th>
            <th class="text-end">Total Amount</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">@Html.DisplayFor(modelItem => item.SaleNumber)</a>
                </td>
                <td>@item.SaleDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@Html.DisplayFor(modelItem => item.PatientName)</td>
                <td>@Html.DisplayFor(modelItem => item.PaymentMethodText)</td>
                <td class="text-end">@item.TotalAmount.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">View Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
