@model UniCareERP.Application.DTOs.Reporting.FinanceReportDto

@{
    ViewData["Title"] = "Finance Report";
}

<h1>Finance Report</h1>

<form asp-action="Finance" method="get">
    <div class="form-row">
        <div class="form-group col-md-4">
            <label for="startDate">Start Date</label>
            <input type="date" id="startDate" name="startDate" value="@(((DateTime)ViewData["StartDate"]).ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="form-group col-md-4">
            <label for="endDate">End Date</label>
            <input type="date" id="endDate" name="endDate" value="@(((DateTime)ViewData["EndDate"]).ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="form-group col-md-4 align-self-end">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                Revenue Summary
            </div>
            <div class="card-body">
                <h5 class="card-title">Total Revenue: @Model.TotalRevenue.ToString("C")</h5>
                <p class="card-text">Procedures: @Model.ProcedureRevenue.ToString("C")</p>
                <p class="card-text">Appointments: @Model.AppointmentRevenue.ToString("C")</p>
                <p class="card-text">Pharmacy: @Model.PharmacyRevenue.ToString("C")</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                Doctor-wise Revenue
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.DoctorWiseRevenue)
                {
                    <li class="list-group-item">@item.DoctorName <span class="float-right">@item.Revenue.ToString("C")</span></li>
                }
            </ul>
        </div>
    </div>
</div>
