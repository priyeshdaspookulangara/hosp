@model IEnumerable<UniCareERP.Application.DTOs.Reporting.ProcedureReportDto>

@{
    ViewData["Title"] = "Procedure Report";
}

<h1>Procedure Report</h1>

<form asp-action="Procedures" method="get">
    <div class="form-row">
        <div class="form-group col-md-4">
            <label for="startDate">Start Date</label>
            <input type="date" id="startDate" name="startDate" value="@(((DateTime)ViewData["StartDate"]).ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="form-group col-md-4">
            <label for="endDate">End Date</label>
            <input type="date" id="endDate" name="endDate" value="@(((DateTime)ViewData["EndDate"]).ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="form-group col-md-4 align-self-end">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Procedure Name</th>
            <th>Patient Name</th>
            <th>Surgeon Name</th>
            <th>Date</th>
            <th class="text-right">Total Charges</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProcedureName</td>
                <td>@item.PatientName</td>
                <td>@item.SurgeonName</td>
                <td>@item.ProcedureDate.ToShortDateString()</td>
                <td class="text-right">@item.TotalCharges.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
