@model UniCareERP.Application.DTOs.Emergency.UpdateEmergencyCaseDto

@{
    ViewData["Title"] = "Edit Emergency Case";
}

<h1>Edit Emergency Case</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label class="control-label">Patient</label>
                <p>@ViewBag.PatientName</p>
            </div>
            <div class="form-group">
                <label asp-for="CaseDescription" class="control-label"></label>
                <textarea asp-for="CaseDescription" class="form-control"></textarea>
                <span asp-validation-for="CaseDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<UniCareERP.Domain.Enums.EmergencyCaseStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
