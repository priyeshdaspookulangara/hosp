@model IEnumerable<UniCareERP.Application.DTOs.HR.LeaveRequestDto>

@{
    ViewData["Title"] = "My Leave Requests";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Request New Leave</a>
</p>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Request Date</th>
            <th>Leave Type</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RequestedDate.ToString("yyyy-MM-dd")</td>
                <td>@item.LeaveTypeText</td>
                <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-@(GetStatusBadgeClass(item.Status))">
                        @item.StatusText
                    </span>
                </td>
                <td>
                    @if (item.Status == UniCareERP.Domain.Enums.LeaveRequestStatus.Pending)
                    {
                        <form asp-action="Cancel" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this request?');">
                            <button type="submit" class="btn btn-sm btn-outline-warning">Cancel</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@functions {
    string GetStatusBadgeClass(UniCareERP.Domain.Enums.LeaveRequestStatus status)
    {
        return status switch
        {
            UniCareERP.Domain.Enums.LeaveRequestStatus.Pending => "secondary",
            UniCareERP.Domain.Enums.LeaveRequestStatus.Approved => "success",
            UniCareERP.Domain.Enums.LeaveRequestStatus.Rejected => "danger",
            UniCareERP.Domain.Enums.LeaveRequestStatus.Cancelled => "warning",
            _ => "light",
        };
    }
}
