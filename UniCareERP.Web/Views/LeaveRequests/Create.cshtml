@model UniCareERP.Application.DTOs.HR.CreateLeaveRequestDto

@{
    ViewData["Title"] = "Request New Leave";
}

<h1>@ViewData["Title"]</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

             <div class="form-group mb-2">
                <label asp-for="LeaveType" class="control-label"></label>
                <select asp-for="LeaveType" class="form-select" asp-items="Html.GetEnumSelectList<UniCareERP.Domain.Enums.LeaveType>()">
                    <option value="">-- Select Leave Type --</option>
                </select>
                <span asp-validation-for="LeaveType" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-2">
                        <label asp-for="StartDate" class="control-label"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                </div>
                 <div class="col-md-6">
                    <div class="form-group mb-2">
                        <label asp-for="EndDate" class="control-label"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Reason" class="control-label"></label>
                <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Submit Request" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
