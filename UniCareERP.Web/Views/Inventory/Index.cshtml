@model IEnumerable<UniCareERP.Application.DTOs.Inventory.InventoryItemDto>

@{
    ViewData["Title"] = "Inventory Item Master";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Item</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().ItemCode)</th>
            <th>@Html.DisplayNameFor(model => model.First().Name)</th>
            <th>@Html.DisplayNameFor(model => model.First().Category)</th>
            <th class="text-end">@Html.DisplayNameFor(model => model.First().QuantityInStock)</th>
            <th class="text-end">@Html.DisplayNameFor(model => model.First().UnitPrice)</th>
            <th>@Html.DisplayNameFor(model => model.First().IsActive)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.IsActive ? "" : "table-secondary text-muted")">
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">@Html.DisplayFor(modelItem => item.ItemCode)</a>
                </td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Category)</td>
                <td class="text-end">@Html.DisplayFor(modelItem => item.QuantityInStock) @Html.DisplayFor(modelItem => item.UnitOfMeasure)</td>
                <td class="text-end">@item.UnitPrice.ToString("C")</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info ms-1">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
